---
import { profile } from '@/data/profile';
import type { Lang } from '@/data/i18n';
import { t } from '@/data/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

// TODO(caio): swap to /cv/CV-CaioHenrique-EN.pdf when EN version is ready
const cvHref = profile.links.cv;
const sectionAriaLabel = lang === 'pt' ? 'Apresentação' : 'Introduction';
const cvAriaLabel = lang === 'pt' ? 'Baixar currículo (PDF)' : 'Download CV (PDF)';
---
<section
  id="about"
  aria-label={sectionAriaLabel}
  class="relative w-screen left-1/2 -translate-x-1/2 overflow-hidden bg-bg py-20 md:py-28"
>
  <!-- Atmosphere layers (decorative) — wallpaper z-0, grid z-1, scan z-2 -->
  <div class="hero-wallpaper-layer" aria-hidden="true"></div>
  <div class="hero-grid-pattern" aria-hidden="true"></div>
  <div class="hero-scan-accent" aria-hidden="true"></div>

  <!-- Content wrapper (above atmosphere) -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <!-- [1] Status pill (single eyebrow — replaces "Welcome" + "Hey there") -->
    <div
      role="status"
      aria-live="polite"
      class="inline-flex items-center gap-2.5 px-3 py-1.5 border-2 border-phosphor bg-phosphor/5 mb-10 md:mb-14"
    >
      <span
        aria-hidden="true"
        class="inline-block w-2 h-2 bg-phosphor animate-pulse-phosphor"
      ></span>
      <span class="font-mono text-[11px] sm:text-xs text-phosphor uppercase tracking-[0.18em]">
        {t.heroStatusAvailable[lang]}
      </span>
    </div>

    <!-- [2] 2-col grid: avatar (120px) | content (1fr) -->
    <div class="grid gap-8 md:gap-10 md:grid-cols-[120px_1fr] items-start">
      <!-- COL 1: avatar + version label -->
      <div class="flex flex-col items-start">
        <div class="pixel-frame-phosphor w-24 md:w-[120px] aspect-square overflow-hidden">
          <img
            src="/images/profile/profile_1.png"
            alt={t.heroAvatarAlt[lang]}
            class="w-full h-full object-cover smooth"
            style="object-position: center 25%;"
            loading="eager"
            fetchpriority="high"
            width="120"
            height="120"
          />
        </div>
        <p class="font-mono text-[11px] text-ink-mute mt-4 tracking-wider">
          {t.heroVersionLabel[lang]}
        </p>
      </div>

      <!-- COL 2: content (label → H1 role → pitch → CTAs → trust) -->
      <div class="min-w-0">
        <!-- Name demoted to a code-comment label (inversion of hierarchy) -->
        <p class="font-mono text-sm text-ink-dim mb-4">
          {t.heroNameLabel[lang]}
        </p>

        <!-- H1: role-first, two lines, "DevSecOps" highlighted in phosphor -->
        <h1 class="font-pixel text-[22px] md:text-[28px] leading-[1.4] text-ink">
          <span class="block">
            {t.heroRoleLine1[lang]}{' '}
            <span class="text-phosphor text-glow-phosphor">
              {t.heroRoleHighlight[lang]}
            </span>
          </span>
          <span class="block">{t.heroRoleLine2[lang]}</span>
        </h1>

        <!-- Primary pitch with amber metric -->
        <p class="font-mono text-[15px] text-ink leading-relaxed mt-6 max-w-2xl">
          {t.heroPitchPrimary[lang]}{' '}
          <span class="text-amber font-medium">{t.heroPitchPrimaryMetric[lang]}</span>{' '}
          {t.heroPitchPrimaryRest[lang]}
        </p>

        <!-- Secondary pitch -->
        <p class="font-mono text-sm text-ink-dim leading-relaxed mt-3 max-w-2xl">
          {t.heroPitchSecondary[lang]}
        </p>

        <!-- CTAs: only 2 -->
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#impact" class="pixel-btn-primary">
            {t.heroCtaImpact[lang]}
          </a>
          <a
            href={cvHref}
            download
            class="pixel-btn-ghost"
            aria-label={cvAriaLabel}
          >
            {t.heroCtaCV[lang]}
          </a>
        </div>

        <!-- Trust line (replaces inline social links — those live in the footer) -->
        <div class="mt-10 pt-4 border-t border-line">
          <p class="font-mono text-xs text-ink-dim">
            {t.heroTrustLine[lang]}{' '}
            <span class="text-ink">{t.heroTrustCompanies[lang]}</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
