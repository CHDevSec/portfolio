---
import { profile } from '@/data/profile';
import type { Lang } from '@/data/i18n';
import { t } from '@/data/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

// TODO(caio): swap to /cv/CV-CaioHenrique-EN.pdf when EN version is ready
const cvHref = profile.links.cv;
const sectionAriaLabel = lang === 'pt' ? 'Apresentação' : 'Introduction';
const cvAriaLabel = lang === 'pt' ? 'Baixar currículo (PDF)' : 'Download CV (PDF)';
---
<section
  id="about"
  aria-label={sectionAriaLabel}
  class="relative w-screen left-1/2 -translate-x-1/2 overflow-hidden bg-bg flex-1 flex items-center py-8 md:py-12"
>
  <!-- Atmosphere layers (decorative) — wallpaper z-0, grid z-1, scan z-2 -->
  <div class="hero-wallpaper-layer" aria-hidden="true"></div>
  <div class="hero-grid-pattern" aria-hidden="true"></div>
  <div class="hero-scan-accent" aria-hidden="true"></div>

  <!-- Content wrapper (above atmosphere) -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 w-full">
    <!-- [1] Status pill (single eyebrow — replaces "Welcome" + "Hey there") -->
    <div
      role="status"
      aria-live="polite"
      class="inline-flex items-center gap-2.5 px-3 py-1.5 border-2 border-success bg-success/5 mb-6 md:mb-8"
    >
      <span
        aria-hidden="true"
        class="inline-block w-2 h-2 bg-success animate-pulse-success"
      ></span>
      <span class="font-mono text-[11px] sm:text-xs text-success uppercase tracking-[0.18em]">
        {t.heroStatusAvailable[lang]}
      </span>
    </div>

    <!-- [2] Identity grid: avatar | H1 (always 2-col) -->
    <div class="grid gap-x-4 md:gap-x-10 grid-cols-[80px_1fr] md:grid-cols-[120px_1fr] items-start">
      <!-- COL 1: avatar + (mobile-only name below) + version -->
      <div class="flex flex-col items-start">
        <div class="pixel-frame-phosphor w-20 md:w-[120px] aspect-square overflow-hidden">
          <img
            src="/portfolio/images/profile/profile_1.png"
            alt={t.heroAvatarAlt[lang]}
            class="w-full h-full object-cover smooth"
            style="object-position: center 25%;"
            loading="eager"
            fetchpriority="high"
            width="120"
            height="120"
          />
        </div>
        <!-- Mobile-only: name label tucked under the avatar -->
        <p class="md:hidden font-mono text-[11px] text-ink-dim mt-3">
          {t.heroNameLabel[lang]}
        </p>
        <p class="font-mono text-[11px] text-ink-mute mt-2 md:mt-4 tracking-wider">
          {t.heroVersionLabel[lang]}
        </p>
      </div>

      <!-- COL 2: (desktop-only name above) + H1 -->
      <div class="min-w-0">
        <!-- Desktop-only: name label above H1 -->
        <p class="hidden md:block font-mono text-sm text-ink-dim mb-2">
          {t.heroNameLabel[lang]}
        </p>

        <!-- H1: role-first, "Security" highlighted in primary -->
        <h1 class="font-pixel text-[22px] md:text-[28px] leading-[1.4] text-ink">
          <span class="block">
            <span class="text-primary text-glow-primary">
              {t.heroRoleHighlight[lang]}
            </span>
          </span>
          <span class="block">{t.heroRoleLine2[lang]}</span>
        </h1>

        <!-- Subtitle: stack summary (terms stay in EN by design) -->
        <p class="font-mono text-sm md:text-base text-ink-secondary mt-2">
          {t.heroSubtitle[lang]}
        </p>
      </div>
    </div>

    <!-- [3] Body block — full-width on mobile, aligned with col 2 on desktop (120 avatar + 40 gap = 160) -->
    <div class="mt-6 md:mt-4 md:pl-[160px]">
      <!-- Primary pitch with amber metric -->
      <p class="font-mono text-[15px] text-ink leading-relaxed max-w-2xl">
        {t.heroPitchPrimary[lang]}{' '}
        <span class="text-amber font-medium">{t.heroPitchPrimaryMetric[lang]}</span>{' '}
        {t.heroPitchPrimaryRest[lang]}
      </p>

      <!-- Secondary pitch -->
      <p class="font-mono text-sm text-ink-dim leading-relaxed mt-3 max-w-2xl">
        {t.heroPitchSecondary[lang]}
      </p>

      <!-- CTAs: only 2 -->
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="#impact" class="pixel-btn-primary glitch-on-hover">
          {t.heroCtaImpact[lang]}
        </a>
        <a
          href={cvHref}
          download
          class="pixel-btn-ghost glitch-on-hover"
          aria-label={cvAriaLabel}
        >
          {t.heroCtaCV[lang]}
        </a>
      </div>

      <!-- Trust line (replaces inline social links — those live in the footer) -->
      <div class="mt-6 pt-3 border-t border-primary/30">
        <p class="font-mono text-xs text-ink-dim">
          {t.heroTrustLine[lang]}{' '}
          <span class="text-ink">{t.heroTrustCompanies[lang]}</span>
        </p>
      </div>
    </div>
  </div>
</section>
