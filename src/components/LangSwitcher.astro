---
import type { Lang } from '@/data/i18n';
import { localizedUrl, stripLang } from '@/data/i18n';

interface Props {
  current: Lang;
}

const { current } = Astro.props;

// Compute the equivalent path in the OTHER language
const cleanPath = stripLang(Astro.url.pathname);
const usaUrl = localizedUrl(cleanPath, 'en');
const brUrl = localizedUrl(cleanPath, 'pt');
---
<div class="flex items-center gap-1 border-2 border-line p-0.5" role="group" aria-label="Language switcher">
  <a
    href={usaUrl}
    class={`flex items-center gap-1.5 px-2 py-1 transition ${
      current === 'en'
        ? 'bg-phosphor/10 text-phosphor'
        : 'text-ink-dim hover:text-ink'
    }`}
    aria-label="English (US)"
    aria-current={current === 'en' ? 'true' : 'false'}
  >
    <!-- Pixel USA flag (16x10 grid) -->
    <svg viewBox="0 0 16 10" width="22" height="14" shape-rendering="crispEdges" aria-hidden="true">
      <!-- Stripes (red & white) -->
      <rect x="0" y="0" width="16" height="1" fill="#B22234"/>
      <rect x="0" y="1" width="16" height="1" fill="#fff"/>
      <rect x="0" y="2" width="16" height="1" fill="#B22234"/>
      <rect x="0" y="3" width="16" height="1" fill="#fff"/>
      <rect x="0" y="4" width="16" height="1" fill="#B22234"/>
      <rect x="0" y="5" width="16" height="1" fill="#fff"/>
      <rect x="0" y="6" width="16" height="1" fill="#B22234"/>
      <rect x="0" y="7" width="16" height="1" fill="#fff"/>
      <rect x="0" y="8" width="16" height="1" fill="#B22234"/>
      <rect x="0" y="9" width="16" height="1" fill="#fff"/>
      <!-- Canton (blue) -->
      <rect x="0" y="0" width="7" height="5" fill="#3C3B6E"/>
      <!-- Pixel stars -->
      <rect x="1" y="1" width="1" height="1" fill="#fff"/>
      <rect x="3" y="1" width="1" height="1" fill="#fff"/>
      <rect x="5" y="1" width="1" height="1" fill="#fff"/>
      <rect x="2" y="2" width="1" height="1" fill="#fff"/>
      <rect x="4" y="2" width="1" height="1" fill="#fff"/>
      <rect x="6" y="2" width="1" height="1" fill="#fff"/>
      <rect x="1" y="3" width="1" height="1" fill="#fff"/>
      <rect x="3" y="3" width="1" height="1" fill="#fff"/>
      <rect x="5" y="3" width="1" height="1" fill="#fff"/>
    </svg>
    <span class="font-pixel text-[9px]">EN</span>
  </a>

  <a
    href={brUrl}
    class={`flex items-center gap-1.5 px-2 py-1 transition ${
      current === 'pt'
        ? 'bg-phosphor/10 text-phosphor'
        : 'text-ink-dim hover:text-ink'
    }`}
    aria-label="Português (Brasil)"
    aria-current={current === 'pt' ? 'true' : 'false'}
  >
    <!-- Pixel BR flag (16x10 grid) -->
    <svg viewBox="0 0 16 10" width="22" height="14" shape-rendering="crispEdges" aria-hidden="true">
      <!-- Green base -->
      <rect width="16" height="10" fill="#009C3B"/>
      <!-- Yellow diamond (simplified pixel) -->
      <rect x="7" y="2" width="2" height="1" fill="#FFDF00"/>
      <rect x="6" y="3" width="4" height="1" fill="#FFDF00"/>
      <rect x="5" y="4" width="6" height="1" fill="#FFDF00"/>
      <rect x="4" y="5" width="8" height="1" fill="#FFDF00"/>
      <rect x="5" y="6" width="6" height="1" fill="#FFDF00"/>
      <rect x="6" y="7" width="4" height="1" fill="#FFDF00"/>
      <rect x="7" y="8" width="2" height="1" fill="#FFDF00"/>
      <!-- Blue circle (center) -->
      <rect x="7" y="4" width="2" height="2" fill="#002776"/>
      <rect x="6" y="5" width="1" height="1" fill="#002776"/>
      <rect x="9" y="5" width="1" height="1" fill="#002776"/>
      <!-- White star (single pixel) -->
      <rect x="7" y="5" width="1" height="1" fill="#fff"/>
    </svg>
    <span class="font-pixel text-[9px]">PT</span>
  </a>
</div>
