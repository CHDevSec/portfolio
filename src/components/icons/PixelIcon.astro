---
type IconName =
  | 'shield' | 'lock' | 'key' | 'terminal' | 'server' | 'cloud'
  | 'bug' | 'eye' | 'pipe' | 'book' | 'chip' | 'gear'
  | 'fingerprint' | 'cert' | 'sword' | 'skull' | 'flag' | 'heart';

interface Props {
  name: IconName;
  size?: number;
  class?: string;
  color?: string; // hex without #
}

