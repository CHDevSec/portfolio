---
import { profile } from '@/data/profile';
import type { Lang } from '@/data/i18n';
import { localizedUrl, t } from '@/data/i18n';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const home = localizedUrl('/', lang);
const blog = localizedUrl('/blog', lang);

const links = [
  { href: `${home}#experience`, label: t.navExperience[lang] },
  { href: `${home}#how`, label: t.navMethod[lang] },
  { href: `${home}#projects`, label: t.navProjects[lang] },
  { href: `${home}#skills`, label: t.navSkills[lang] },
  { href: `${home}#certs`, label: t.navCerts[lang] },
  { href: blog, label: t.navNotes[lang] },
];
---
<header class="sticky top-0 z-40 bg-bg/80 backdrop-blur border-b-2 border-line">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">
    <a href={home} class="flex items-center gap-2 group shrink-0">
      <span class="font-pixel text-xs text-phosphor group-hover:text-glow-phosphor transition">
        ▸ {profile.handle}
      </span>
    </a>

    <ul class="hidden lg:flex items-center gap-1">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="px-3 py-2 font-mono text-xs uppercase text-ink-dim hover:text-phosphor transition"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2 shrink-0">
      <LangSwitcher current={lang} />
      <a
        href={profile.links.cv}
        download
        class="hidden sm:inline-flex items-center gap-1 px-3 py-2 font-pixel text-[10px] uppercase text-phosphor border-2 border-line hover:border-phosphor hover:bg-phosphor/10 transition"
      >
        {t.navCV[lang]}
      </a>
      <button
        type="button"
        id="menu-toggle"
        class="lg:hidden font-pixel text-xs text-phosphor border-2 border-line p-2 hover:border-phosphor"
        aria-label="Toggle menu"
      >
        ☰
      </button>
    </div>
  </nav>

  <ul id="mobile-menu" class="lg:hidden hidden border-t-2 border-line bg-bg-raised">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="block px-6 py-3 font-mono text-sm text-ink-dim hover:text-phosphor hover:bg-bg-card border-b border-line"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  document.querySelectorAll('#mobile-menu a').forEach((a) =>
    a.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>
